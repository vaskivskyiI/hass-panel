server {
    listen 80;
    server_name panel.example.local;

    gzip on;
    gzip_types text/plain text/css application/javascript application/json image/svg+xml;
    gzip_min_length 1024;

    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    location = /runtime-config.json {
        add_header Cache-Control "no-store" always;
        proxy_pass http://127.0.0.1:8088/runtime-config.json;
    }

    location = /sw.js {
        add_header Cache-Control "no-cache, no-store, must-revalidate" always;
        proxy_pass http://127.0.0.1:8088/sw.js;
    }

    location /assets/ {
        add_header Cache-Control "public, immutable, max-age=31536000" always;
        proxy_pass http://127.0.0.1:8088/assets/;
    }

    location /internal/ {
        proxy_pass http://127.0.0.1:8088/internal/;
    }

    location /api/ {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_pass http://127.0.0.1:8088/api/;
    }

    location /ha/ {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_pass http://127.0.0.1:8088/ha/;
    }

    location / {
        add_header Cache-Control "no-store" always;
        proxy_pass http://127.0.0.1:8088;
    }
}
